<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.lastwar.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>__REPO_DIR__/scripts/control_once.sh</string>
    <string>--backend</string>
    <string>macos_mirroring</string>
    <string>--use-manual-rect</string>
    <string>--execute</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__REPO_DIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>1800</integer>
  <key>StandardOutPath</key>
  <string>__REPO_DIR__/runs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO_DIR__/runs/launchd.err.log</string>
</dict>
</plist>
